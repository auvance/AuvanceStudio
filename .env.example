# ------------------------------------------------------------------
# Auvance Studio — environment variables
# Copy to .env.local (gitignored) and fill in. NEVER commit real keys.
# ------------------------------------------------------------------

# Public site URL — used for canonical URLs, sitemap, OG/social images.
# Set this in Vercel → Project → Settings → Environment Variables too.
NEXT_PUBLIC_SITE_URL=https://www.auvancestudio.ca

# Contact form delivery (optional).
# If these are unset, the contact forms gracefully fall back to opening
# the visitor's email client (mailto) — nothing breaks.
# Server-side only; never exposed to the browser.
#
# CONTACT_FROM_EMAIL must be on a domain verified in Resend (SPF/DKIM).
# Recommended: send from a dedicated subdomain to protect your main mail
# reputation, e.g. notifications@send.auvancestudio.ca.
# CONTACT_TO_EMAIL is simply where you READ the leads (your inbox).
RESEND_API_KEY=
CONTACT_TO_EMAIL=aakif@auvancestudio.ca
CONTACT_FROM_EMAIL=Auvance <notifications@send.auvancestudio.ca>
